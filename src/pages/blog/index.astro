---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

const categories = [...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout
  title="All Reviews & Guides"
  description="Browse all PawDore dog product reviews, comparisons, and buyer's guides."
>
  <div class="container">
    <h1 style="margin-bottom: 0.5rem;">All Reviews & Guides</h1>
    <p style="color: #555b6e; margin-bottom: 2rem;">Browse our latest dog product reviews and buying guides.</p>

    <div class="article-grid">
      {allPosts.map((post) => (
        <article class="article-card">
          <div class="article-card-body">
            <span class="category-tag">{post.data.category}</span>
            <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="meta">{formatDate(post.data.pubDate)}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
