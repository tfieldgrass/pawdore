---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

// Map posts to hero images
const imageMap: { [key: string]: string } = {
  'best-harness-for-dogs-that-pull': 'https://images.unsplash.com/photo-1601758228041-f3b2795255f1?w=600&h=300&fit=crop',
  'best-dog-food-for-sensitive-stomachs': 'https://images.unsplash.com/photo-1589924691995-400dc9ecc119?w=600&h=300&fit=crop',
  'best-dog-beds-for-large-breeds': 'https://images.unsplash.com/photo-1534361960057-19889db9621e?w=600&h=300&fit=crop',
  'kong-vs-nylabone-which-is-better': 'https://images.unsplash.com/photo-1535930749574-1399327ce78f?w=600&h=300&fit=crop',
  'best-automatic-dog-feeder': 'https://images.unsplash.com/photo-1600804340584-c7db2eacf0bf?w=600&h=300&fit=crop',
  'best-gps-dog-tracker': 'https://images.unsplash.com/photo-1530281700549-e82e7bf110d6?w=600&h=300&fit=crop',
  'best-dog-shampoo-itchy-skin': 'https://images.unsplash.com/photo-1516734212186-a967f81ad0d7?w=600&h=300&fit=crop',
};

function getImageForPost(postId: string): string {
  return imageMap[postId] || 'https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=600&h=300&fit=crop';
}
---

<BaseLayout
  title="Honest Dog Product Reviews & Buyer's Guides"
  description="PawDore helps you find the best products for your dog. Expert reviews, comparisons, and buyer's guides for harnesses, food, beds, toys, and more."
>
  <section class="hero">
    <h1>Find the Best Products for Your Best Friend</h1>
    <p>Honest, research-backed reviews and buyer's guides to help you choose the right gear, food, and care products for your dog.</p>
    <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1200&h=400&fit=crop" alt="Happy dog" />
  </section>

  <div class="container">
    <h2 style="margin-bottom: 0.5rem;">Latest Reviews & Guides</h2>
    <p style="color: #555b6e; margin-bottom: 1rem;">In-depth product reviews to help you make the best choice for your pup.</p>

    {allPosts.length === 0 && (
      <p style="text-align: center; color: #999; padding: 3rem 0;">
        New reviews coming soon! We're currently testing and researching products.
      </p>
    )}

    <div class="article-grid">
      {allPosts.map((post) => (
        <article class="article-card">
          <img src={getImageForPost(post.id)} alt={post.data.title} />
          <div class="article-card-body">
            <span class="category-tag">{post.data.category}</span>
            <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="meta">{formatDate(post.data.pubDate)}</div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
