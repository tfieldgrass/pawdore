---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="robots" content="index, follow" />
  <title>{title} | PawDore</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style is:inline>
    /* PawDore - Modern Professional Design */
    :root {
      --color-navy: #1a1a2e;
      --color-teal: #16697a;
      --color-teal-light: #2b8e9e;
      --color-orange: #ff6b35;
      --color-orange-dark: #e55a25;
      --color-white: #ffffff;
      --color-light-gray: #f5f7fa;
      --color-medium-gray: #d0d4d9;
      --color-dark-gray: #4a4a4a;
      --color-text: #2c3e50;
      --max-width: 1100px;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      color: var(--color-text);
      background-color: var(--color-white);
      line-height: 1.6;
      font-size: 16px;
    }

    a {
      color: var(--color-teal);
      text-decoration: none;
      transition: color 0.2s;
    }

    a:hover {
      color: var(--color-teal-light);
    }

    img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
    }

    /* Header */
    .site-header {
      background: var(--color-navy);
      color: var(--color-white);
      padding: 1rem 0;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .header-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .site-logo {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--color-white);
      text-decoration: none;
      letter-spacing: -0.5px;
    }

    .site-logo span {
      color: var(--color-orange);
    }

    nav {
      display: flex;
      gap: 0;
    }

    nav a {
      color: rgba(255, 255, 255, 0.8);
      margin-left: 2.5rem;
      font-weight: 500;
      font-size: 0.95rem;
      text-decoration: none;
      transition: color 0.2s;
    }

    nav a:hover {
      color: var(--color-orange);
      text-decoration: none;
    }

    /* Main content */
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    /* Hero section */
    .hero {
      text-align: center;
      padding: 4rem 1.5rem;
      background: linear-gradient(135deg, #0d3b66 0%, var(--color-teal) 100%);
      color: var(--color-white);
    }

    .hero h1 {
      font-size: 2.8rem;
      font-weight: 800;
      margin-bottom: 1.25rem;
      line-height: 1.2;
    }

    .hero p {
      font-size: 1.1rem;
      opacity: 0.95;
      max-width: 650px;
      margin: 0 auto;
      line-height: 1.6;
    }

    .hero img {
      margin-top: 2rem;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      max-width: 100%;
    }

    /* Article cards */
    .article-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 2.5rem;
    }

    .article-card {
      background: var(--color-white);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      transition: all 0.3s ease;
      border: 1px solid var(--color-medium-gray);
    }

    .article-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .article-card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 0;
    }

    .article-card-body {
      padding: 1.5rem;
    }

    .article-card .category-tag,
    .category-tag {
      display: inline-block;
      background: var(--color-teal);
      color: var(--color-white);
      padding: 0.35rem 0.85rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.75rem;
    }

    .article-card h3 {
      font-size: 1.2rem;
      margin-bottom: 0.75rem;
      line-height: 1.3;
      font-weight: 700;
    }

    .article-card h3 a {
      color: var(--color-text);
    }

    .article-card h3 a:hover {
      color: var(--color-teal);
      text-decoration: none;
    }

    .article-card p {
      color: var(--color-dark-gray);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .article-card .meta {
      margin-top: 1rem;
      font-size: 0.8rem;
      color: #888;
    }

    /* Blog post styles */
    .post-header {
      text-align: center;
      padding: 3rem 0 2rem;
    }

    .post-header h1 {
      font-size: 2.4rem;
      font-weight: 800;
      line-height: 1.25;
      max-width: 850px;
      margin: 0 auto 1.25rem;
      color: var(--color-navy);
    }

    .post-meta {
      color: var(--color-dark-gray);
      font-size: 0.95rem;
    }

    .post-content {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 0;
    }

    .post-content h2 {
      font-size: 1.8rem;
      margin: 2.5rem 0 1rem;
      color: var(--color-navy);
      font-weight: 700;
    }

    .post-content h3 {
      font-size: 1.35rem;
      margin: 2rem 0 0.75rem;
      color: var(--color-teal);
      font-weight: 700;
    }

    .post-content p {
      margin-bottom: 1.25rem;
      line-height: 1.7;
    }

    .post-content ul,
    .post-content ol {
      margin-bottom: 1.25rem;
      padding-left: 1.75rem;
    }

    .post-content li {
      margin-bottom: 0.5rem;
      line-height: 1.6;
    }

    /* Product recommendation box */
    .product-pick {
      background: var(--color-light-gray);
      border: 3px solid var(--color-teal);
      border-radius: 10px;
      padding: 1.75rem;
      margin: 2.5rem 0;
    }

    .product-pick h3 {
      color: var(--color-teal);
      margin: 0 0 0.75rem;
      font-size: 1.3rem;
    }

    .product-pick .badge {
      display: inline-block;
      background: var(--color-orange);
      color: var(--color-white);
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .affiliate-btn {
      display: inline-block;
      background: var(--color-orange);
      color: var(--color-white);
      padding: 0.8rem 1.75rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.95rem;
      margin-top: 1rem;
      text-decoration: none;
      transition: background 0.2s;
      cursor: pointer;
    }

    .affiliate-btn:hover {
      background: var(--color-orange-dark);
      color: var(--color-white);
      text-decoration: none;
    }

    /* Comparison table */
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      font-size: 0.95rem;
      border: 1px solid var(--color-medium-gray);
      border-radius: 8px;
      overflow: hidden;
    }

    .comparison-table th {
      background: var(--color-navy);
      color: var(--color-white);
      padding: 1rem 1.25rem;
      text-align: left;
      font-weight: 700;
    }

    .comparison-table td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--color-medium-gray);
    }

    .comparison-table tr:nth-child(even) {
      background: var(--color-light-gray);
    }

    .comparison-table tr:last-child td {
      border-bottom: none;
    }

    /* Pros/Cons */
    .pros-cons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin: 2rem 0;
    }

    .pros,
    .cons {
      padding: 1.5rem;
      border-radius: 8px;
    }

    .pros {
      background: rgba(22, 105, 122, 0.08);
      border-left: 4px solid var(--color-teal);
    }

    .cons {
      background: rgba(255, 107, 53, 0.08);
      border-left: 4px solid var(--color-orange);
    }

    .pros h4 {
      color: var(--color-teal);
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }

    .cons h4 {
      color: var(--color-orange);
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }

    .pros ul,
    .cons ul {
      list-style: none;
      padding-left: 0;
    }

    .pros li,
    .cons li {
      margin-bottom: 0.5rem;
      padding-left: 1.5rem;
      position: relative;
    }

    .pros li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--color-teal);
      font-weight: bold;
    }

    .cons li::before {
      content: '✗';
      position: absolute;
      left: 0;
      color: var(--color-orange);
      font-weight: bold;
    }

    /* Footer */
    .site-footer {
      background: var(--color-navy);
      color: rgba(255, 255, 255, 0.8);
      padding: 2.5rem 0;
      margin-top: 4rem;
      text-align: center;
      font-size: 0.85rem;
    }

    .site-footer a {
      color: var(--color-orange);
    }

    .site-footer a:hover {
      color: #ff8555;
    }

    .affiliate-disclosure {
      background: rgba(22, 105, 122, 0.1);
      border-left: 4px solid var(--color-teal);
      padding: 1rem 1.25rem;
      border-radius: 6px;
      font-size: 0.9rem;
      color: var(--color-text);
      margin: 2rem 0;
    }

    .affiliate-disclosure strong {
      color: var(--color-teal);
    }

    /* Main heading styles */
    h1 {
      color: var(--color-navy);
      font-weight: 800;
    }

    h2 {
      color: var(--color-navy);
      font-weight: 700;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero {
        padding: 2.5rem 1.5rem;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .hero p {
        font-size: 1rem;
      }

      .article-grid {
        grid-template-columns: 1fr;
      }

      .pros-cons {
        grid-template-columns: 1fr;
      }

      nav {
        flex-direction: column;
        gap: 0.5rem;
      }

      nav a {
        margin-left: 0;
        font-size: 0.85rem;
      }

      .post-header h1 {
        font-size: 1.8rem;
      }

      .post-content {
        padding: 1rem 0;
      }

      .comparison-table {
        font-size: 0.85rem;
      }

      .comparison-table th,
      .comparison-table td {
        padding: 0.75rem 0.5rem;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">Paw<span>Dore</span></a>
      <nav>
        <a href="/">Home</a>
        <a href="/blog">Reviews</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} PawDore. All rights reserved.</p>
      <p style="margin-top: 0.75rem;">
        <a href="/affiliate-disclosure">Affiliate Disclosure</a> &middot;
        <a href="/privacy">Privacy Policy</a>
      </p>
      <p style="margin-top: 0.75rem; font-size: 0.75rem; opacity: 0.7;">
        PawDore is a participant in affiliate programs including the Amazon Services LLC Associates Program.
        As an Amazon Associate, we earn from qualifying purchases.
      </p>
    </div>
  </footer>
</body>
</html>
